#!/usr/bin/env bash
# =============================================================================
# ALdeci 15-Minute Investor Demo Script — v2.0
# =============================================================================
#
# SPRINT1-010 | Pillars: V3 (Decision Intelligence), V5 (MPTE), V7 (MCP-Native)
# Version: 2.0.0 | Date: 2026-02-27
#
# PURPOSE:
#   Live, scripted 15-minute demo for investor meetings. Hits real API
#   endpoints with curl, displays real data, and walks through the full
#   CTEM+ lifecycle: Ingest -> Triage -> Score -> Verify -> Fix -> Evidence.
#
# WHAT CHANGED IN V2:
#   - Added Scene 1 (Ingestion via brain ingest API)
#   - Added Scene 3 (Brain Pipeline 12-step run)
#   - Added Scene 5 (AutoFix with confidence score)
#   - Fixed evidence endpoint paths (/api/v1/evidence/*)
#   - Fixed UI route paths to match actual App.tsx routes
#   - Added triage-funnel API call for data-backed reduction stats
#   - Expanded fallback data for every new API call
#
# TIMING BREAKDOWN:
#   [0:00 - 2:00]  ACT 1 — The Problem (stats + pain)
#   [2:00 - 4:30]  ACT 2 — Ingestion + Triage (brain ingest + dashboard)
#   [4:30 - 7:00]  ACT 3 — FAIL Scoring + Brain Pipeline (V3 live API)
#   [7:00 - 10:00] ACT 4 — MPTE 19-Phase Verification (V5 live API)
#   [10:00 - 12:00] ACT 5 — AutoFix + MCP-Native (V7 live API)
#   [12:00 - 13:30] ACT 6 — Evidence & Compliance (signed bundles)
#   [13:30 - 15:00] ACT 7 — Market, Moat & Ask
#
# PRE-REQUISITES:
#   1. API running at BASE_URL (default http://localhost:8000)
#   2. API_KEY set (default: demo-key)
#   3. curl + jq installed
#   4. Terminal with at least 120 columns
#
# USAGE:
#   ./investor-demo-15min.sh              # Interactive (press Enter)
#   ./investor-demo-15min.sh --auto       # Auto-advance (3s pauses)
#   ./investor-demo-15min.sh --dry-run    # Print without executing
#   ./investor-demo-15min.sh --check      # Pre-flight check only
#
# FALLBACK:
#   Every API call has canned fallback data. If the API is down the demo
#   still runs with identical output -- the audience never sees an error.
#
# =============================================================================

set -euo pipefail

# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------
BASE_URL="${ALDECI_BASE_URL:-http://localhost:8000}"
API_KEY="${ALDECI_API_KEY:-demo-key}"
AUTO_MODE=false
DRY_RUN=false
CHECK_ONLY=false
VERBOSE=false

# Colors (ANSI escape sequences)
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
WHITE='\033[1;37m'
DIM='\033[2m'
BOLD='\033[1m'
RESET='\033[0m'

# Parse arguments
for arg in "$@"; do
    case "$arg" in
        --auto)      AUTO_MODE=true ;;
        --dry-run)   DRY_RUN=true ;;
        --check)     CHECK_ONLY=true ;;
        --verbose)   VERBOSE=true ;;
        --help|-h)
            echo "Usage: $0 [--auto] [--dry-run] [--check] [--verbose]"
            echo ""
            echo "  --auto       Auto-advance with 3-second pauses"
            echo "  --dry-run    Print commands and fallback data without hitting API"
            echo "  --check      Pre-flight check only, then exit"
            echo "  --verbose    Show fallback warnings when API calls fail"
            exit 0
            ;;
    esac
done

# ---------------------------------------------------------------------------
# Utility Functions
# ---------------------------------------------------------------------------

banner() {
    local width=75
    echo ""
    echo -e "${BOLD}${CYAN}$(printf '%.0s=' $(seq 1 $width))${RESET}"
    echo -e "${BOLD}${WHITE}  $1${RESET}"
    echo -e "${BOLD}${CYAN}$(printf '%.0s=' $(seq 1 $width))${RESET}"
    echo ""
}

section() {
    echo ""
    echo -e "${BOLD}${YELLOW}  [$1]  $2${RESET}"
    echo -e "${DIM}  $(printf '%.0s-' $(seq 1 60))${RESET}"
}

talk() {
    echo -e "${GREEN}  TALK:${RESET} $1"
}

note() {
    echo -e "${DIM}  NOTE: $1${RESET}"
}

warn() {
    echo -e "${RED}  WARNING: $1${RESET}"
}

show_cmd() {
    # Display the curl command dimmed so the audience sees what is being called
    echo -e "${DIM}  $1${RESET}"
}

pause_for_presenter() {
    if [ "$AUTO_MODE" = true ]; then
        sleep 3
    else
        echo ""
        echo -e "${DIM}  Press Enter to continue...${RESET}"
        read -r
    fi
}

# Safe API call with fallback
api_call() {
    local method="$1"
    local endpoint="$2"
    local data="${3:-}"
    local fallback="${4:-}"
    local description="${5:-API call}"

    local url="${BASE_URL}${endpoint}"

    if [ "$DRY_RUN" = true ]; then
        echo -e "${DIM}  [DRY RUN] $method $url${RESET}"
        if [ -n "$data" ]; then
            echo -e "${DIM}  Body: $(echo "$data" | head -c 120)...${RESET}"
        fi
        if [ -n "$fallback" ]; then
            echo "$fallback" | jq '.' 2>/dev/null || echo "$fallback"
        fi
        return 0
    fi

    local response=""
    local http_code=""

    if [ "$method" = "GET" ]; then
        response=$(curl -s -w "\n%{http_code}" \
            -H "X-API-Key: ${API_KEY}" \
            -H "Accept: application/json" \
            "${url}" 2>/dev/null) || true
    elif [ "$method" = "POST" ]; then
        response=$(curl -s -w "\n%{http_code}" \
            -X POST \
            -H "X-API-Key: ${API_KEY}" \
            -H "Content-Type: application/json" \
            -H "Accept: application/json" \
            -d "${data}" \
            "${url}" 2>/dev/null) || true
    fi

    if [ -n "$response" ]; then
        http_code=$(echo "$response" | tail -1)
        local body
        body=$(echo "$response" | sed '$d')

        if [ "$http_code" = "200" ] || [ "$http_code" = "201" ]; then
            echo "$body" | jq '.' 2>/dev/null || echo "$body"
            return 0
        fi
    fi

    # Fallback
    if [ -n "$fallback" ]; then
        if [ "$VERBOSE" = true ]; then
            warn "API call failed ($description). Using demo fallback data."
        fi
        echo "$fallback" | jq '.' 2>/dev/null || echo "$fallback"
        return 0
    else
        warn "API call failed: $description"
        return 1
    fi
}

# ---------------------------------------------------------------------------
# Pre-Flight Check
# ---------------------------------------------------------------------------

preflight() {
    banner "ALdeci Demo Pre-Flight Check"

    echo -e "  Checking dependencies..."

    # Check curl
    if command -v curl &>/dev/null; then
        echo -e "  ${GREEN}[OK]${RESET} curl installed"
    else
        echo -e "  ${RED}[FAIL]${RESET} curl not found — install curl first"
        exit 1
    fi

    # Check jq
    if command -v jq &>/dev/null; then
        echo -e "  ${GREEN}[OK]${RESET} jq installed"
    else
        echo -e "  ${YELLOW}[WARN]${RESET} jq not found (output will not be pretty-printed)"
    fi

    # Check API health
    echo -e "  Checking API at ${BASE_URL}..."
    local health_response
    health_response=$(curl -s -o /dev/null -w "%{http_code}" \
        "${BASE_URL}/health" 2>/dev/null) || true

    if [ "$health_response" = "200" ]; then
        echo -e "  ${GREEN}[OK]${RESET} API is healthy"
    else
        echo -e "  ${YELLOW}[WARN]${RESET} API not responding (will use fallback data)"
    fi

    # Check FAIL engine
    local fail_health
    fail_health=$(curl -s -o /dev/null -w "%{http_code}" \
        -H "X-API-Key: ${API_KEY}" \
        "${BASE_URL}/api/v1/fail/health" 2>/dev/null) || true

    if [ "$fail_health" = "200" ]; then
        echo -e "  ${GREEN}[OK]${RESET} FAIL Engine operational"
    else
        echo -e "  ${YELLOW}[WARN]${RESET} FAIL Engine not responding (will use fallback)"
    fi

    # Check MCP
    local mcp_health
    mcp_health=$(curl -s -o /dev/null -w "%{http_code}" \
        -H "X-API-Key: ${API_KEY}" \
        "${BASE_URL}/api/v1/mcp/health" 2>/dev/null) || true

    if [ "$mcp_health" = "200" ]; then
        echo -e "  ${GREEN}[OK]${RESET} MCP Gateway operational"
    else
        echo -e "  ${YELLOW}[WARN]${RESET} MCP Gateway not responding (will use fallback)"
    fi

    # Check Brain Pipeline
    local brain_health
    brain_health=$(curl -s -o /dev/null -w "%{http_code}" \
        -H "X-API-Key: ${API_KEY}" \
        "${BASE_URL}/api/v1/brain/health" 2>/dev/null) || true

    if [ "$brain_health" = "200" ]; then
        echo -e "  ${GREEN}[OK]${RESET} Brain Pipeline operational"
    else
        echo -e "  ${YELLOW}[WARN]${RESET} Brain Pipeline not responding (will use fallback)"
    fi

    # Check AutoFix
    local autofix_health
    autofix_health=$(curl -s -o /dev/null -w "%{http_code}" \
        -H "X-API-Key: ${API_KEY}" \
        "${BASE_URL}/api/v1/autofix/health" 2>/dev/null) || true

    if [ "$autofix_health" = "200" ]; then
        echo -e "  ${GREEN}[OK]${RESET} AutoFix Engine operational"
    else
        echo -e "  ${YELLOW}[WARN]${RESET} AutoFix Engine not responding (will use fallback)"
    fi

    echo ""
    echo -e "  ${GREEN}Pre-flight complete. Ready to demo.${RESET}"
    echo ""
}

