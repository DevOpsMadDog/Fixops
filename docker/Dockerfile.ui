# ============================================
# ALDECI UI — React 19 production build (Nginx)
# ============================================
# Multi-stage: Node builds Vite assets → Nginx serves them.
# Used by docker-compose.enterprise.yml for the aldeci-ui service.
#
# Build (from repo root):
#   docker build -f docker/Dockerfile.ui -t aldeci-ui:enterprise .
# The nginx-ui.conf is mounted at runtime via compose volume.
# ============================================

# ── Stage 1: Build React app ─────────────────────────────────────────────────
FROM node:20-alpine AS builder

WORKDIR /app

# Install deps first (layer-cache friendly)
COPY suite-ui/aldeci-ui-new/package.json suite-ui/aldeci-ui-new/package-lock.json ./
RUN npm ci

# Copy full source
COPY suite-ui/aldeci-ui-new/ .

# Build-time API URL — overridden at nginx proxy level in production
ARG VITE_API_URL=http://localhost:8000
ENV VITE_API_URL=$VITE_API_URL

RUN npx vite build

# ── Stage 2: Nginx runtime ───────────────────────────────────────────────────
FROM nginx:1.27-alpine

# Copy built assets from builder
COPY --from=builder /app/dist /usr/share/nginx/html

# Default nginx config (overridden by compose volume mount of nginx-ui.conf)
# Provides SPA fallback + /nginx-health endpoint without requiring volume mount
RUN printf 'server {\n\
  listen 80;\n\
  root /usr/share/nginx/html;\n\
  index index.html;\n\
  location /nginx-health {\n\
    access_log off;\n\
    return 200 "ok\\n";\n\
    add_header Content-Type text/plain;\n\
  }\n\
  location / {\n\
    try_files $uri $uri/ /index.html;\n\
  }\n\
}\n' > /etc/nginx/conf.d/default.conf

LABEL org.opencontainers.image.title="ALDECI UI"
LABEL org.opencontainers.image.description="ALDECI React 19 frontend — Nginx enterprise build"
LABEL org.opencontainers.image.vendor="ALDECI"

EXPOSE 80

HEALTHCHECK --interval=15s --timeout=5s --start-period=10s --retries=3 \
    CMD curl -sf http://localhost:80/nginx-health || exit 1
