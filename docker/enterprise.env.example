# ============================================
# ALDECI Enterprise Stack — Environment Template
# ============================================
# Copy this file to docker/enterprise.env and fill in your values.
# NEVER commit enterprise.env to git (it's in .gitignore).
#
# Usage:
#   cp docker/enterprise.env.example docker/enterprise.env
#   # Edit enterprise.env with your secrets
#   docker compose -f docker/docker-compose.enterprise.yml --env-file docker/enterprise.env up -d
# ============================================

# ─── ALDECI Core ─────────────────────────────────────────────────────────────
FIXOPS_MODE=enterprise
FIXOPS_LOG_LEVEL=warning
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
FIXOPS_API_TOKEN=
FIXOPS_JWT_SECRET=
FIXOPS_WORKERS=1
ALDECI_SEED_DEMO=0
# Set to 1 to enable LLM Council consensus decisions
FIXOPS_USE_COUNCIL=0

# ─── LLM Providers ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
# Local Ollama (if running natively, not in Docker)
FIXOPS_OLLAMA_URL=

# ─── PostgreSQL (ALDECI primary DB) ──────────────────────────────────────────
POSTGRES_DB=aldeci
POSTGRES_USER=aldeci
# CHANGE THIS in production
POSTGRES_PASSWORD=aldeci_pw_change_me
POSTGRES_PORT=5432

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_PORT=6379

# ─── TrustGraph ──────────────────────────────────────────────────────────────
TRUSTGRAPH_PORT=8888
TRUSTGRAPH_LOG_LEVEL=warning

# ─── LocalStack (Fake AWS) ───────────────────────────────────────────────────
LOCALSTACK_PORT=4566
LOCALSTACK_ENDPOINT=http://localstack:4566
LOCALSTACK_DEBUG=0
# LocalStack uses any non-empty string for test credentials
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1

# ─── Wazuh SIEM ──────────────────────────────────────────────────────────────
WAZUH_API_PORT=55000
WAZUH_DASHBOARD_PORT=443
WAZUH_API_URL=https://wazuh:55000
WAZUH_API_USER=wazuh-wui
# CHANGE THIS in production
WAZUH_API_PASSWORD=MyS3cr37P450r.*-

# ─── Shuffle SOAR ────────────────────────────────────────────────────────────
SHUFFLE_PORT=3001
SHUFFLE_URL=http://shuffle:3001
SHUFFLE_USERNAME=admin
# CHANGE THIS in production
SHUFFLE_PASSWORD=password
# Generate in Shuffle UI after first login: Settings → API Keys
SHUFFLE_AUTHORIZATION=

# ─── NetBox CMDB ─────────────────────────────────────────────────────────────
NETBOX_PORT=8080
NETBOX_URL=http://netbox:8080
NETBOX_DB_NAME=netbox
NETBOX_DB_USER=netbox
# CHANGE THIS in production
NETBOX_DB_PASSWORD=netbox_pw_change_me
# Must be ≥50 chars. Generate: python3 -c "import secrets; print(secrets.token_urlsafe(50))"
NETBOX_SECRET_KEY=change-me-in-production-min-50-chars-long-secret-key-here
NETBOX_SUPERUSER_NAME=admin
NETBOX_SUPERUSER_EMAIL=admin@aldeci.local
# CHANGE THIS in production
NETBOX_SUPERUSER_PASSWORD=admin
# 40-char hex token for API access. Generate: python3 -c "import secrets; print(secrets.token_hex(20))"
NETBOX_TOKEN=0123456789abcdef0123456789abcdef01234567

# ─── Service ports (override if defaults conflict) ────────────────────────────
API_PORT=8000
UI_PORT=3000
