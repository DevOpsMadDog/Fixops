              "shortDescription": {
                "text": "SQL Injection"
              },
              "defaultConfiguration": {
                "level": "error"
              }
            },
            {
              "id": "CWE-79",
              "shortDescription": {
                "text": "Cross-Site Scripting"
              },
              "defaultConfiguration": {
                "level": "error"
              }
            },
            {
              "id": "CWE-200",
              "shortDescription": {
                "text": "Exposure of Sensitive Information (PHI)"
              },
              "defaultConfiguration": {
                "level": "error"
              }
            },
            {
              "id": "CWE-312",
              "shortDescription": {
                "text": "Cleartext Storage of Sensitive Information (PHI)"
              },
              "defaultConfiguration": {
                "level": "error"
              }
            },
            {
              "id": "CWE-319",
              "shortDescription": {
                "text": "Cleartext Transmission of PHI"
              },
              "defaultConfiguration": {
                "level": "error"
              }
