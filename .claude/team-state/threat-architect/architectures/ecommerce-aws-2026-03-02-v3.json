    {"id": "C030", "name": "Secrets Manager", "type": "secret_store", "technology": "AWS Secrets Manager", "tier": "security", "exposed": false},
    {"id": "C031", "name": "Cognito User Pool", "type": "identity", "technology": "Amazon Cognito", "tier": "security", "exposed": true},
    {"id": "C032", "name": "CloudWatch + X-Ray", "type": "monitoring", "technology": "AWS CloudWatch, AWS X-Ray", "tier": "observability", "exposed": false},
    {"id": "C033", "name": "ECS Fargate Cluster", "type": "container_platform", "technology": "AWS ECS Fargate", "tier": "infrastructure", "exposed": false},
    {"id": "C034", "name": "ECR Registry", "type": "container_registry", "technology": "Amazon ECR", "tier": "infrastructure", "exposed": false},
    {"id": "C035", "name": "Stripe Payment Gateway", "type": "external_service", "technology": "Stripe API v2024-01", "tier": "external", "exposed": false, "pci_scope": true}
