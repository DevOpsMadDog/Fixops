  "connections": [
    {"from": "C001", "to": "C002", "protocol": "HTTPS/TLS1.3", "description": "SPA served via CDN"},
    {"from": "C002", "to": "C003", "protocol": "HTTPS", "description": "CDN routes through WAF"},
    {"from": "C003", "to": "C005", "protocol": "HTTPS", "description": "WAF forwards to ALB"},
    {"from": "C004", "to": "C002", "protocol": "DNS/HTTPS", "description": "DNS resolves to CDN"},
    {"from": "C005", "to": "C007", "protocol": "HTTP/8080", "description": "ALB routes /auth/* to Auth Service"},
    {"from": "C005", "to": "C008", "protocol": "HTTP/8081", "description": "ALB routes /users/* to User Service"},
    {"from": "C005", "to": "C009", "protocol": "HTTP/3000", "description": "ALB routes /catalog/* to Catalog Service"},
    {"from": "C005", "to": "C010", "protocol": "HTTP/3001", "description": "ALB routes /cart/* to Cart Service"},
    {"from": "C005", "to": "C011", "protocol": "HTTP/8082", "description": "ALB routes /orders/* to Order Service"},
    {"from": "C005", "to": "C012", "protocol": "HTTP/8083", "description": "ALB routes /payments/* to Payment Service"},
    {"from": "C005", "to": "C013", "protocol": "HTTP/8000", "description": "ALB routes /inventory/* to Inventory Service"},
    {"from": "C005", "to": "C015", "protocol": "HTTP/8001", "description": "ALB routes /search/* to Search Service"},
    {"from": "C006", "to": "C017", "protocol": "HTTPS", "description": "API GW triggers Order Processor Lambda"},
    {"from": "C007", "to": "C031", "protocol": "HTTPS", "description": "Auth Service uses Cognito for identity"},
    {"from": "C007", "to": "C022", "protocol": "TCP/6379", "description": "Auth Service caches sessions in Redis"},
    {"from": "C008", "to": "C020", "protocol": "TCP/5432-TLS", "description": "User Service reads/writes user data"},
    {"from": "C009", "to": "C023", "protocol": "HTTPS/9200", "description": "Catalog Service queries OpenSearch"},
    {"from": "C010", "to": "C022", "protocol": "TCP/6379", "description": "Cart Service stores carts in Redis"},
    {"from": "C011", "to": "C021", "protocol": "TCP/5432-TLS", "description": "Order Service reads/writes orders"},
    {"from": "C011", "to": "C026", "protocol": "HTTPS", "description": "Order Service enqueues to SQS FIFO"},
    {"from": "C012", "to": "C035", "protocol": "HTTPS/TLS1.3", "description": "Payment Service calls Stripe API"},
    {"from": "C012", "to": "C021", "protocol": "TCP/5432-TLS", "description": "Payment Service writes payment records"},
    {"from": "C012", "to": "C029", "protocol": "HTTPS", "description": "Payment Service uses KMS for encryption"},
    {"from": "C013", "to": "C020", "protocol": "TCP/5432-TLS", "description": "Inventory Service reads/writes stock"},
    {"from": "C014", "to": "C027", "protocol": "HTTPS", "description": "Notification Service publishes to SNS"},
    {"from": "C015", "to": "C023", "protocol": "HTTPS/9200", "description": "Search Service queries OpenSearch"},
    {"from": "C016", "to": "C022", "protocol": "TCP/6379", "description": "Recommendation Engine reads user behavior cache"},
    {"from": "C017", "to": "C026", "protocol": "HTTPS", "description": "Lambda polls SQS for new orders"},
    {"from": "C017", "to": "C028", "protocol": "HTTPS", "description": "Lambda emits domain events to EventBridge"},
    {"from": "C018", "to": "C024", "protocol": "HTTPS", "description": "Image Resizer reads/writes S3 media"},
    {"from": "C019", "to": "C028", "protocol": "HTTPS", "description": "Fraud Detector receives payment events"},
    {"from": "C019", "to": "C021", "protocol": "TCP/5432-TLS", "description": "Fraud Detector queries order history"},
    {"from": "C033", "to": "C034", "protocol": "HTTPS", "description": "ECS pulls images from ECR"},
    {"from": "C032", "to": "C033", "protocol": "API", "description": "CloudWatch monitors ECS tasks"},
    {"from": "C030", "to": "C012", "protocol": "HTTPS", "description": "Secrets Manager provides Stripe keys"},
    {"from": "C011", "to": "C025", "protocol": "HTTPS", "description": "Order Service stores documents in S3"}
  ],
  "trust_boundaries": [
    {
      "id": "TB001",
      "name": "Internet → Edge (Untrusted → WAF)",
      "from_zone": "internet",
      "to_zone": "edge",
      "components_inside": ["C001"],
      "components_outside": ["C002", "C003", "C004"],
      "controls": ["TLS 1.3", "WAF managed rules", "Rate limiting", "Bot detection", "DDoS protection (Shield Advanced)"]
    },
    {
      "id": "TB002",
      "name": "Edge → Application (DMZ → Private VPC)",
      "from_zone": "edge",
      "to_zone": "application",
      "components_inside": ["C002", "C003", "C005", "C006"],
      "components_outside": ["C007", "C008", "C009", "C010", "C011", "C012", "C013", "C014", "C015", "C016"],
      "controls": ["Security groups", "NACLs", "VPC flow logs", "ALB access logs"]
    },
    {
      "id": "TB003",
      "name": "Application → Data (Compute → Storage)",
      "from_zone": "application",
      "to_zone": "data",
      "components_inside": ["C007", "C008", "C009", "C010", "C011", "C012", "C013", "C014", "C015", "C016"],
      "components_outside": ["C020", "C021", "C022", "C023", "C024", "C025"],
      "controls": ["IAM roles per service", "TLS in transit", "Encryption at rest (KMS)", "DB authentication (IAM auth)"]
    },
    {
      "id": "TB004",
      "name": "PCI CDE Boundary",
      "from_zone": "non-pci",
      "to_zone": "pci-cde",
      "components_inside": ["C012", "C019", "C021", "C025", "C035"],
      "components_outside": ["C007", "C008", "C009", "C010", "C011"],
      "controls": ["Network segmentation", "Dedicated subnets", "Enhanced logging", "Token vault", "HSM for key storage"]
    },
    {
      "id": "TB005",
      "name": "VPC → External Services",
      "from_zone": "vpc",
      "to_zone": "external",
      "components_inside": ["C012"],
      "components_outside": ["C035"],
      "controls": ["VPC endpoints", "NAT gateway", "Outbound security groups", "TLS pinning"]
    },
    {
      "id": "TB006",
      "name": "Serverless Boundary",
      "from_zone": "ecs",
      "to_zone": "lambda",
      "components_inside": ["C033"],
      "components_outside": ["C017", "C018", "C019"],
      "controls": ["Lambda VPC attachment", "Minimal IAM execution roles", "Reserved concurrency", "DLQ for failures"]
    }
  ]
}
