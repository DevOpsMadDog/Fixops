{
  "architecture": {
    "name": "Acme E-Commerce Platform v3",
    "version": "3.0.0",
    "date": "2026-03-02",
    "cloud": "AWS",
    "region": "us-east-1",
    "compliance": ["PCI-DSS-v4.0", "SOC2-Type-II", "GDPR"],
    "description": "Enterprise e-commerce platform with microservices on ECS Fargate, event-driven processing, and PCI-compliant payment flows"
  },
  "components": [
    {"id": "C001", "name": "React SPA (Storefront)", "type": "frontend", "technology": "React 18.3, Next.js 14.1, TypeScript 5.4", "tier": "presentation", "exposed": true},
    {"id": "C002", "name": "CloudFront CDN", "type": "cdn", "technology": "AWS CloudFront", "tier": "edge", "exposed": true},
    {"id": "C003", "name": "AWS WAF v2", "type": "waf", "technology": "AWS WAFv2 with managed rule groups", "tier": "edge", "exposed": true},
    {"id": "C004", "name": "Route 53 DNS", "type": "dns", "technology": "AWS Route 53", "tier": "edge", "exposed": true},
    {"id": "C005", "name": "Application Load Balancer", "type": "load_balancer", "technology": "AWS ALB", "tier": "network", "exposed": false},
    {"id": "C006", "name": "API Gateway (REST)", "type": "api_gateway", "technology": "AWS API Gateway v2", "tier": "network", "exposed": true},
    {"id": "C007", "name": "Auth Service", "type": "microservice", "technology": "Spring Boot 3.2.3, Java 21", "tier": "application", "exposed": false, "pci_scope": false},
    {"id": "C008", "name": "User Service", "type": "microservice", "technology": "Spring Boot 3.2.3, Java 21", "tier": "application", "exposed": false, "data_classification": "PII"},
    {"id": "C009", "name": "Catalog Service", "type": "microservice", "technology": "Node.js 20.11, Express 4.18", "tier": "application", "exposed": false},
    {"id": "C010", "name": "Cart Service", "type": "microservice", "technology": "Node.js 20.11, Express 4.18", "tier": "application", "exposed": false},
    {"id": "C011", "name": "Order Service", "type": "microservice", "technology": "Spring Boot 3.2.3, Java 21", "tier": "application", "exposed": false, "pci_scope": true},
    {"id": "C012", "name": "Payment Service", "type": "microservice", "technology": "Spring Boot 3.2.3, Java 21", "tier": "application", "exposed": false, "pci_scope": true, "data_classification": "PCI-CHD"},
    {"id": "C013", "name": "Inventory Service", "type": "microservice", "technology": "Python 3.12, FastAPI 0.109", "tier": "application", "exposed": false},
    {"id": "C014", "name": "Notification Service", "type": "microservice", "technology": "Python 3.12, FastAPI 0.109", "tier": "application", "exposed": false},
    {"id": "C015", "name": "Search Service", "type": "microservice", "technology": "Python 3.12, FastAPI 0.109, OpenSearch", "tier": "application", "exposed": false},
    {"id": "C016", "name": "Recommendation Engine", "type": "microservice", "technology": "Python 3.12, FastAPI 0.109, scikit-learn", "tier": "application", "exposed": false},
    {"id": "C017", "name": "Lambda: Order Processor", "type": "serverless", "technology": "AWS Lambda (Python 3.12)", "tier": "processing", "exposed": false},
    {"id": "C018", "name": "Lambda: Image Resizer", "type": "serverless", "technology": "AWS Lambda (Node.js 20)", "tier": "processing", "exposed": false},
    {"id": "C019", "name": "Lambda: Fraud Detector", "type": "serverless", "technology": "AWS Lambda (Python 3.12)", "tier": "processing", "exposed": false, "pci_scope": true},
    {"id": "C020", "name": "RDS PostgreSQL (Users)", "type": "database", "technology": "Amazon RDS PostgreSQL 16.1", "tier": "data", "exposed": false, "data_classification": "PII"},
    {"id": "C021", "name": "RDS PostgreSQL (Orders)", "type": "database", "technology": "Amazon RDS PostgreSQL 16.1, Multi-AZ", "tier": "data", "exposed": false, "pci_scope": true},
    {"id": "C022", "name": "ElastiCache Redis Cluster", "type": "cache", "technology": "Amazon ElastiCache Redis 7.1", "tier": "data", "exposed": false},
    {"id": "C023", "name": "OpenSearch Domain", "type": "search_engine", "technology": "Amazon OpenSearch 2.11", "tier": "data", "exposed": false},
    {"id": "C024", "name": "S3: Media Assets", "type": "object_storage", "technology": "Amazon S3", "tier": "data", "exposed": false},
    {"id": "C025", "name": "S3: Order Documents", "type": "object_storage", "technology": "Amazon S3 (SSE-KMS)", "tier": "data", "exposed": false, "pci_scope": true},
    {"id": "C026", "name": "SQS: Order Queue", "type": "message_queue", "technology": "Amazon SQS FIFO", "tier": "messaging", "exposed": false},
    {"id": "C027", "name": "SNS: Notification Topic", "type": "message_topic", "technology": "Amazon SNS", "tier": "messaging", "exposed": false},
    {"id": "C028", "name": "EventBridge: Domain Events", "type": "event_bus", "technology": "Amazon EventBridge", "tier": "messaging", "exposed": false},
