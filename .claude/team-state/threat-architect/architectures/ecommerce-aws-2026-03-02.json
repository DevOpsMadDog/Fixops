{
  "architecture": {
    "name": "ecommerce-platform-v2",
    "version": "2.5.0",
    "cloud": "AWS",
    "region": "us-east-1",
    "date": "2026-03-02",
    "compliance": ["PCI-DSS-v4.0", "SOC2-Type-II", "GDPR", "CCPA"],
    "environment": "production"
  },
  "trust_boundaries": [
    {
      "id": "TB-01",
      "name": "Internet → WAF/CloudFront",
      "type": "external",
      "description": "Untrusted internet traffic enters through CloudFront CDN and AWS WAF"
    },
    {
      "id": "TB-02",
      "name": "WAF → Application Load Balancer",
      "type": "dmz",
      "description": "WAF-filtered traffic passes to ALB in public subnet"
    },
    {
      "id": "TB-03",
      "name": "ALB → ECS/Fargate Services",
      "type": "application",
      "description": "Load-balanced traffic enters private subnet with ECS tasks"
    },
    {
      "id": "TB-04",
      "name": "Services → Data Tier",
      "type": "data",
      "description": "Application services access RDS, ElastiCache, S3 via VPC endpoints"
    },
    {
      "id": "TB-05",
      "name": "Services → External APIs",
      "type": "external-outbound",
      "description": "Outbound calls to Stripe, Twilio, SendGrid through NAT Gateway"
    }
  ],
  "components": [
    {
      "id": "C-001",
      "name": "cloudfront-cdn",
      "type": "cdn",
      "technology": "AWS CloudFront",
      "version": "2026.1",
      "trust_boundary": "TB-01",
      "data_classification": "public",
      "description": "Edge CDN serving static assets, React SPA, and API caching",
      "ports": [443],
      "protocols": ["HTTPS", "HTTP/2", "HTTP/3"],
      "dependencies": ["C-002", "C-010"]
    },
    {
      "id": "C-002",
      "name": "aws-waf",
      "type": "firewall",
      "technology": "AWS WAF v2",
      "version": "2.0",
      "trust_boundary": "TB-01",
      "data_classification": "internal",
      "description": "Web Application Firewall with OWASP Top 10 managed rule groups",
      "dependencies": ["C-003"]
    },
    {
      "id": "C-003",
      "name": "application-load-balancer",
      "type": "load_balancer",
      "technology": "AWS ALB",
      "version": "2.0",
      "trust_boundary": "TB-02",
      "data_classification": "internal",
      "description": "Layer 7 load balancer with path-based routing to ECS services",
      "ports": [443, 8080],
      "dependencies": ["C-004", "C-005", "C-006", "C-007"]
    },
    {
      "id": "C-004",
