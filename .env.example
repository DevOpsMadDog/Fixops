# =============================================================================
# ALdeci / ALDECI Platform — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in the required values.
# DO NOT commit a populated .env file to version control.
#
# Quick start (minimal):
#   cp .env.example .env
#   # Set FIXOPS_API_TOKEN to a strong random string
#   docker compose up
# =============================================================================


# =============================================================================
# API — SERVER RUNTIME
# =============================================================================

# Port the API server listens on (Docker: host-side port mapping)
ALDECI_PORT=8000

# Bind host for uvicorn (0.0.0.0 = all interfaces)
# FIXOPS_HOST=0.0.0.0

# Number of uvicorn workers (increase for production)
# FIXOPS_WORKERS=1

# Platform mode: enterprise | demo | development | test
FIXOPS_MODE=enterprise

# Disable API rate limiting — set to 1 in CI/test environments
# FIXOPS_DISABLE_RATE_LIMIT=0

# Enable verbose per-request logging (performance impact in production)
# FIXOPS_DETAILED_LOGGING=0

# Comma-separated list of allowed CORS origins (required in production)
# FIXOPS_ALLOWED_ORIGINS=https://your-domain.com,https://app.your-domain.com

# Exit immediately on startup errors (recommended for container health checks)
# FIXOPS_FAIL_FAST=0

# Version metadata (injected by CI/CD pipeline — do not set manually)
# FIXOPS_VERSION=0.1.0
# FIXOPS_BUILD_DATE=unknown
# FIXOPS_GIT_COMMIT=unknown


# =============================================================================
# AUTH
# =============================================================================

# REQUIRED: API bearer token — generate with: openssl rand -hex 32
FIXOPS_API_TOKEN=

# JWT signing secret — generate with: openssl rand -hex 32 (>=32 chars)
# If unset, a random secret is auto-generated (tokens won't survive restarts)
FIXOPS_JWT_SECRET=

# JWT access token expiry (minutes)
# FIXOPS_JWT_EXP_MINUTES=30

# JWT access token expiry (hours, users_router compat)
# FIXOPS_JWT_EXPIRE_HOURS=2

# JWT refresh token expiry (days)
# FIXOPS_JWT_REFRESH_DAYS=7

# SSO / OIDC (Enterprise SSO — requires FIXOPS_SSO_ENABLED=true)
# FIXOPS_SSO_ENABLED=false
# FIXOPS_SSO_PROVIDER=okta
# FIXOPS_OIDC_CLIENT_ID=
# FIXOPS_OIDC_CLIENT_SECRET=
# FIXOPS_OIDC_ISSUER_URL=https://your-org.okta.com


# =============================================================================
# DATABASE / STORAGE
# =============================================================================

# Root directory for all SQLite databases and state files
# FIXOPS_DATA_DIR=.fixops_data

# Override path for the primary app-config SQLite DB
# FIXOPS_DB_PATH=

# Enable WAL journal mode on SQLite connections (recommended)
# FIXOPS_SQLITE_WAL=true

# Directory for generated reports
# FIXOPS_REPORTS_DIR=/tmp/fixops_reports

# Default finding retention period in days
# FIXOPS_RETENTION_DAYS=365


# =============================================================================
# QUEUE
# =============================================================================

# Task queue backend: local (in-process) | redis
# FIXOPS_QUEUE_MODE=local

# Redis connection URL (required when FIXOPS_QUEUE_MODE=redis)
# FIXOPS_REDIS_URL=redis://localhost:6379/0


# =============================================================================
# LLM / AI
# =============================================================================

# OpenAI API key (for GPT-4o, o3, etc.)
# OPENAI_API_KEY=sk-...

# Anthropic API key (for Claude Opus/Sonnet)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter API key (free models: Qwen, Kimi, Llama, Gemma)
# OPENROUTER_API_KEY=sk-or-v1-...

# Enable Karpathy LLM Council for security decisions
# FIXOPS_USE_COUNCIL=0

# Minimum vote fraction to reach consensus (0.0-1.0)
# FIXOPS_CONSENSUS_THRESHOLD=0.6

# Ollama local inference base URL (e.g. Gemma 4 via Docker)
# FIXOPS_OLLAMA_URL=http://localhost:11434

# vLLM self-hosted inference base URL
# FIXOPS_VLLM_URL=


# =============================================================================
# THREAT INTEL FEEDS
# =============================================================================

# Feed refresh interval in seconds (default: 1 hour)
# FIXOPS_FEEDS_REFRESH_INTERVAL=3600

# Age in seconds before a feed entry is considered stale (default: 24 hours)
# FIXOPS_FEEDS_STALE_THRESHOLD=86400


# =============================================================================
# NOTIFICATIONS — SMTP
# =============================================================================

# FIXOPS_SMTP_HOST=smtp.gmail.com
# FIXOPS_SMTP_PORT=587
# FIXOPS_SMTP_USER=alerts@your-domain.com
# FIXOPS_SMTP_PASSWORD=
# FIXOPS_SMTP_FROM=aldeci@your-domain.com
# FIXOPS_SMTP_TLS=true


# =============================================================================
# NOTIFICATIONS — SLACK
# =============================================================================

# Slack Bot OAuth token (xoxb-...)
# FIXOPS_SLACK_TOKEN=

# Slack incoming webhook URL (alternative to bot token)
# FIXOPS_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...


# =============================================================================
# CSPM — CLOUD CREDENTIALS
# =============================================================================

# --- AWS ---
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# FIXOPS_AWS_ROLE_ARN=   # optional: cross-account scanning role ARN

# --- Azure ---
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_SUBSCRIPTION_ID=

# --- GCP ---
# GCP_PROJECT_ID=
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GOOGLE_APPLICATION_CREDENTIALS_JSON=   # inline JSON (alternative to file path)


# =============================================================================
# EXTERNAL INTEGRATIONS
# =============================================================================

# --- Jira ---
# FIXOPS_JIRA_URL=https://your-org.atlassian.net
# FIXOPS_JIRA_USER=your-email@example.com
# FIXOPS_JIRA_TOKEN=
# FIXOPS_JIRA_PROJECT=SEC
# FIXOPS_JIRA_FINDINGS_JQL=project=SEC AND labels=aldeci

# --- GitHub ---
# FIXOPS_GITHUB_TOKEN=ghp_...
# FIXOPS_GITHUB_OWNER=your-org
# FIXOPS_GITHUB_REPO=your-repo
# FIXOPS_GITHUB_BASE_BRANCH=main

# --- Snyk ---
# FIXOPS_SNYK_TOKEN=
# FIXOPS_SNYK_ORG_ID=

# --- SonarQube ---
# FIXOPS_SONARQUBE_URL=https://sonarqube.your-domain.com
# FIXOPS_SONARQUBE_TOKEN=

# --- Open Policy Agent ---
# FIXOPS_OPA_URL=http://localhost:8181

# Default organisation ID (single-tenant deployments)
# FIXOPS_DEFAULT_ORG=default


# =============================================================================
# LIMITS / CAPACITY
# =============================================================================

# FIXOPS_MAX_FINDINGS=100000
# FIXOPS_MAX_SCANS=1000
# FIXOPS_MAX_MPTE=10


# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable TrustGraph GraphRAG integration
# FIXOPS_FEATURE_TRUSTGRAPH=true

# Enable automated remediation (autofix engine) — use with caution
# FIXOPS_FEATURE_AUTOFIX=false

# Enable attack simulation module (MPTE)
# FIXOPS_FEATURE_ATTACK_SIM=false

# Enable CSPM cloud posture scanning
# FIXOPS_FEATURE_CSPM=true

# Enable threat intelligence feed ingestion
# FIXOPS_FEATURE_FEEDS=true

# Enable LLM Council (alias for FIXOPS_USE_COUNCIL)
# FIXOPS_FEATURE_COUNCIL=false

# Disable anonymous telemetry
# FIXOPS_DISABLE_TELEMETRY=false
#
# CRITICAL: Never commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Authentication & Security ───────────────────────────────
# Generate: python3 -c "import secrets; print(f'fixops_sk_{secrets.token_urlsafe(32)}')"
FIXOPS_API_TOKEN=

# Generate: openssl rand -hex 32
FIXOPS_JWT_SECRET=

# ── Platform Mode ───────────────────────────────────────────
FIXOPS_MODE=enterprise

# ── Server Configuration ────────────────────────────────────
FIXOPS_PORT=3000
API_WORKERS=4
LOG_LEVEL=info

# ── Rate Limiting ───────────────────────────────────────────
# Set to 1 to disable rate limiting (dev only, NOT for production)
FIXOPS_DISABLE_RATE_LIMIT=0

# ── Knowledge Graph ─────────────────────────────────────────
# Interval in seconds between graph rebuilds
GRAPH_INTERVAL=300

# ── Data Storage ────────────────────────────────────────────
FIXOPS_DATA_DIR=.fixops_data
FIXOPS_DB_PATH=data/fixops.db
FIXOPS_BRAIN_DB_PATH=data/brain.db
FIXOPS_AUDIT_DB_PATH=data/audit.db
FIXOPS_EVIDENCE_PATH=data/evidence
FIXOPS_WORM_PATH=data/worm
FIXOPS_RETENTION_DAYS=365

# ── AI / LLM Providers (all optional — works without any) ──
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# FIXOPS_GEMINI_KEY=
FIXOPS_AI_BACKEND=auto
# Options: auto | openai | anthropic | vllm | ollama
FIXOPS_CONSENSUS_THRESHOLD=0.85

# ── Self-Hosted AI (Air-Gapped Mode) ───────────────────────
# FIXOPS_VLLM_URL=http://localhost:8000
# FIXOPS_OLLAMA_URL=http://localhost:11434
# FIXOPS_OLLAMA_MODEL=codellama:13b
# FIXOPS_GGUF_MODEL_PATH=

# ── MPTE (Micro-Pentest Engine) ────────────────────────────
MPTE_BASE_URL=https://localhost:8443
# MPTE_API_TOKEN=
# MPTE_TIMEOUT=30

# ── External Integrations (all optional) ───────────────────
# GitHub (required for PR gating)
# FIXOPS_GITHUB_TOKEN=
# FIXOPS_GITHUB_OWNER=
# FIXOPS_GITHUB_REPO=

# Jira
# FIXOPS_JIRA_URL=https://your-org.atlassian.net
# FIXOPS_JIRA_USER=
# FIXOPS_JIRA_TOKEN=
# FIXOPS_JIRA_PROJECT=

# Slack
# FIXOPS_SLACK_WEBHOOK_URL=

# Snyk
# FIXOPS_SNYK_TOKEN=
# FIXOPS_SNYK_ORG_ID=

# SonarQube
# FIXOPS_SONARQUBE_URL=
# FIXOPS_SONARQUBE_TOKEN=

# Dependency-Track
# DTRACK_URL=
# DTRACK_API_KEY=

# ── Cryptography ───────────────────────────────────────────
# FIXOPS_RSA_PRIVATE_KEY_PATH=
# FIXOPS_RSA_PUBLIC_KEY_PATH=
# FIXOPS_QUANTUM_ENABLED=false
# FIXOPS_FIPS_MODE=false
# FIXOPS_ENCRYPT_AT_REST=false

# ── CORS / Network Security ────────────────────────────────
# FIXOPS_ALLOWED_ORIGINS=http://localhost:3001
# FIXOPS_TRUSTED_PROXIES=
# FIXOPS_MAX_REQUEST_SIZE_MB=10

# ── Database (future — currently uses SQLite) ──────────────
# DATABASE_URL="<set-at-runtime>"

# ── Cloud Scanning (live CSPM — optional) ──────────────────
# AWS_REGION=us-east-1
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=

# ── Observability (optional) ──────────────────────────────
# OTEL_EXPORTER_OTLP_ENDPOINT=http://collector:4318
# FIXOPS_DETAILED_LOGGING=false
# FIXOPS_DISABLE_TELEMETRY=true
