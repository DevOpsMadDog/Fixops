# ===================================================================
# ALdeci CTEM+ Platform — Environment Configuration
# ===================================================================
# Copy this file to `.env` and configure for your environment.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values
#   docker compose -f docker/docker-compose.yml up
#
# NEVER commit the .env file with real secrets!
# ===================================================================

# -------------------------------------------------------------------
# Core Configuration (REQUIRED)
# -------------------------------------------------------------------

# API authentication token — used by all services to authenticate
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
FIXOPS_API_TOKEN=demo-token-change-me

# JWT signing secret — used for user session tokens
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
FIXOPS_JWT_SECRET=demo-jwt-secret-change-me

# Operating mode: enterprise, demo, development
FIXOPS_MODE=enterprise

# Disable rate limiting for development/demo
FIXOPS_DISABLE_RATE_LIMIT=1

# Disable telemetry collection
FIXOPS_DISABLE_TELEMETRY=1

# Data storage directory (relative to app root)
FIXOPS_DATA_DIR=.fixops_data

# -------------------------------------------------------------------
# LLM Provider API Keys (OPTIONAL)
# -------------------------------------------------------------------
# Without these, ALdeci runs in deterministic mode (no AI consensus).
# For air-gapped deployments, use vLLM instead (see VLLM_* below).

# OpenAI (GPT-4o, GPT-4-turbo)
# OPENAI_API_KEY=sk-proj-...

# Anthropic (Claude 3.5 Sonnet, Opus)
# ANTHROPIC_API_KEY=sk-ant-...

# Google AI (Gemini Pro)
# GOOGLE_API_KEY=AIza...

# -------------------------------------------------------------------
# Self-Hosted LLM (Air-Gapped / On-Prem)
# -------------------------------------------------------------------
# For air-gapped deployments, point to your vLLM instance.
# This replaces all cloud LLM providers.

# VLLM_BASE_URL=http://localhost:8001/v1
# VLLM_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct
# VLLM_API_KEY=local-key

# -------------------------------------------------------------------
# Docker Compose Overrides (OPTIONAL)
# -------------------------------------------------------------------
# These override ports and image names in docker-compose.yml.

# API server port (default: 8000)
# FIXOPS_PORT=8000

# UI server port (default: 3001)
# ALDECI_UI_PORT=3001

# Custom image names (for registry-hosted images)
# FIXOPS_IMAGE=fixops:local
# ALDECI_UI_IMAGE=aldeci-ui:local

# -------------------------------------------------------------------
# CORS Configuration (OPTIONAL)
# -------------------------------------------------------------------
# Comma-separated list of allowed origins for CORS.
# Default: allows localhost:3000, localhost:3001, localhost:5173

# FIXOPS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000

# -------------------------------------------------------------------
# MPTE Configuration (OPTIONAL)
# -------------------------------------------------------------------
# Micro-Pentest Engine — only needed if running MPTE sidecar.

# MPTE_BASE_URL=https://localhost:8443

# -------------------------------------------------------------------
# Integration Tokens (OPTIONAL)
# -------------------------------------------------------------------

# Jira integration
# FIXOPS_JIRA_TOKEN=...
# FIXOPS_JIRA_URL=https://yourorg.atlassian.net

# Slack webhook
# FIXOPS_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ServiceNow
# FIXOPS_SERVICENOW_URL=https://yourorg.service-now.com
# FIXOPS_SERVICENOW_TOKEN=...

# -------------------------------------------------------------------
# Evidence Bundle Encryption (OPTIONAL)
# -------------------------------------------------------------------
# For signed evidence bundles (V10 CTEM compliance).
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# FIXOPS_EVIDENCE_KEY=...

# -------------------------------------------------------------------
# Advanced / CI Configuration
# -------------------------------------------------------------------

# Skip path security checks (CI only)
# FIXOPS_SKIP_PATH_SECURITY=1

# JWT token expiration in minutes (default: 120)
# FIXOPS_JWT_EXP_MINUTES=120

# Rate limiting configuration
# FIXOPS_RL_REQ_PER_MIN=60
# FIXOPS_RL_BURST_SIZE=10
